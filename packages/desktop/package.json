{
  "name": "@zuam/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist-electron/main.js",
  "scripts": {
    "dev": "pnpm --filter @zuam/shared build && pnpm run dev:raw",
    "dev:raw": "vite dev --host 127.0.0.1 --port 3000",
    "build": "pnpm --filter @zuam/shared build && vite build && tsc -p tsconfig.electron.json",
    "package:ci": "node ../../tooling/release/package-desktop-release.cjs",
    "typecheck": "pnpm --filter @zuam/shared build && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint src electron vite.config.ts vitest.config.ts --ext .ts,.tsx",
    "test": "pnpm --filter @zuam/shared build && vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-start": "^1.167.16",
    "@zuam/shared": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "jsdom": "^29.0.2",
    "vite": "^8.0.6",
    "vitest": "^4.1.3"
  }
}
