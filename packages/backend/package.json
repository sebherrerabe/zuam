{
  "name": "@zuam/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @zuam/shared build && pnpm run dev:raw",
    "dev:raw": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test --ext .ts",
    "test": "jest --config ./jest.config.cjs --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@zuam/shared": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0"
  }
}
