{
  "name": "@zuam/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "pnpm --filter @zuam/shared build && expo start",
    "build": "pnpm --filter @zuam/shared build && tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm --filter @zuam/shared build && tsc -p tsconfig.json --noEmit",
    "lint": "eslint app src --ext .ts,.tsx",
    "test": "pnpm --filter @zuam/shared build && jest --config ./jest.config.cjs --runInBand"
  },
  "dependencies": {
    "@zuam/shared": "workspace:*",
    "expo": "^55.0.12",
    "expo-router": "~55.0.11",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest-expo": "~55.0.14"
  }
}
